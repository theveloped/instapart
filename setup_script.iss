[Code]
function BysoftInstallDir: String;
var InstallDir: String;
begin
  if RegQueryStringValue(HKLM32, 'SOFTWARE\Bystronic\BySoft7\Programmer', 'InstallDir', InstallDir) then
    result := InstallDir;
end;


function IsBysoftInstalled: boolean;
begin
  result := Length(BysoftInstallDir) > 0
end;


function DesignerInstallDir: String;
var InstallDir: String;
begin
  if RegQueryStringValue(HKLM64, 'SOFTWARE\Bystronic\BySoft7\Designer', 'InstallDir', InstallDir) then
    result := InstallDir
end;


function ParamDesignerInstallDir(Param: String): String;
var InstallDir: String;
begin
  // User path as saved by a previous install
  if RegQueryStringValue(HKA, 'SOFTWARE\SmartPart\BysoftAutopart', 'InstallDir', InstallDir) then
    result := InstallDir

  // Find Designer path on a fresh install
  else
    result := DesignerInstallDir
end;


function IsDesignerInstalled: boolean;
begin
  result := Length(DesignerInstallDir) > 0;
end;


procedure CurPageChanged(CurPageID: Integer);
var Index: Integer;
begin
  if CurPageID = wpSelectTasks then
    begin           
    Index := WizardForm.TasksList.Items.IndexOf('Install Bysoft7 Autopart Add-In');   

    if Index <> -1 then   
      begin
        WizardForm.TasksList.Checked[Index] := IsBysoftInstalled;
        WizardForm.TasksList.ItemEnabled[Index] := IsBysoftInstalled;
      end;
    
    if not IsBysoftInstalled then
      MsgBox('Can not find Bysoft7. To install the Autopart Add-In please install Bysoft7 first and reinstall.', mbInformation, MB_OK);
  end;
end;


procedure CurUninstallStepChanged(CurUninstallStep: TUninstallStep);   
var InstallDir: String;
begin
  if CurUninstallStep = usUninstall then
    begin
      if RegQueryStringValue(HKA, 'SOFTWARE\SmartPart\BysoftAutopart', 'InstallDir', InstallDir) then
        RegWriteStringValue(HKLM64, 'SOFTWARE\Bystronic\BySoft7\Designer', 'InstallDir', InstallDir);
    end;
end;


function BoolToStr(Value: Boolean): String; 
begin
  if Value then
    Result := 'TRUE'
  else
    Result := 'FALSE';
end;


