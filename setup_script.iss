//end;

function CheckSerial(Serial: String): Boolean;
begin
Serial := Trim(Serial);
if Length(Serial) = 41 then
  WizardForm.NextButton.Caption := SetupMessage(msgButtonNext)

else
  WizardForm.NextButton.Caption := 'Trial >';

result := True
end;

