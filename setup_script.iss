; Script generated by the Inno Setup Script Wizard.
; SEE THE DOCUMENTATION FOR DETAILS ON CREATING INNO SETUP SCRIPT FILES!

#define MyAppName "Batch Unfolder"
#define MyAppVersion "1.2"
#define MyAppPublisher "SmartPart"
#define MyAppURL "https://www.smartpart.com/"
#define MyAppExeName "instapart.exe"

[Setup]
AppId={{7D61B417-6610-4B8B-9617-769A0D82EA9E}
AppName={#MyAppName}
AppVersion={#MyAppVersion}
AppPublisher={#MyAppPublisher}
AppPublisherURL={#MyAppURL}
AppSupportURL={#MyAppURL}
AppUpdatesURL={#MyAppURL}
DefaultDirName={autopf}\{#MyAppPublisher}\{#MyAppName}
DefaultGroupName={#MyAppName}
DisableProgramGroupPage=yes
OutputDir=.\dist\setup-1.2-win
OutputBaseFilename=Setup-Instapart
Compression=lzma
SolidCompression=yes
WizardStyle=modern
UserInfoPage=yes 
ChangesAssociations = yes
LicenseFile=EULA.rtf
UninstallDisplayIcon={app}\{#MyAppExeName}

DisableWelcomePage=no
; Installer vertical banner, max resolution: 164x314 px
WizardImageFile=welcome_banner.bmp

[Languages]
Name: "english"; MessagesFile: "compiler:Default.isl"

[Files]
Source: ".\dist\instapart-1.2-win\instapart.exe"; DestDir: "{app}"; Flags: ignoreversion
Source: ".\dist\instapart-1.2-win\*"; DestDir: "{app}"; Flags: ignoreversion recursesubdirs createallsubdirs; Excludes: ".\dist\instapart-1.2-win\Bystronic.Bysoft.BatchUnfold.exe"
; NOTE: Don't use "Flags: ignoreversion" on any shared system files

Source: "C:\Users\Tobias\Desktop\instapart\dist\instapart-1.2-win\Bystronic.Bysoft.BatchUnfold.exe"; DestDir: "{app}\Addin"; Flags: ignoreversion; Tasks: bysoft_autopart;
; NOTE: Same in \Addin folder for Bysoft7

[Icons]
Name: "{group}\{#MyAppName}"; Filename: "{app}\{#MyAppExeName}"

[Tasks]
Name: "bysoft_autopart"; Description: "Install Bysoft7 Autopart Add-In"; GroupDescription: "Add-Ins:";

Name: "assoc_stp"; Description: "Add right-click menu to .stp files"; GroupDescription: "File associations:"; 
Name: "assoc_step"; Description: "Add right-click menu to .step files"; GroupDescription: "File associations:"; 

